{
  "name": "pip",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:local-staging": "node scripts/run-local-staging-dev.mjs dev --webpack",
    "build:local-staging": "node scripts/run-local-staging-dev.mjs build --webpack",
    "start:local-staging": "node scripts/run-local-staging-dev.mjs start",
    "build": "NEXT_PRIVATE_BUILD_WORKER=0 next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "test:e2e:live:final": "node scripts/run-live-smoke.mjs --require-plaid --complete-plaid",
    "capture:live-auth": "node scripts/capture-live-auth-state.mjs",
    "prove:prd": "node scripts/prove-prd-complete.mjs",
    "test:watch": "vitest",
    "check:deployment": "node scripts/check-deployment-env.mjs",
    "check:local-staging": "node scripts/check-deployment-env.mjs --mode=local-beta",
    "check:db-schema-names": "node scripts/check-db-schema-names.mjs",
    "check:live-smoke": "node scripts/check-live-smoke-env.mjs",
    "check:netlify-bundle": "node scripts/check-netlify-bundle.mjs",
    "check:prd-complete": "node scripts/check-prd-complete.mjs",
    "proof:in-app-browser": "node scripts/write-in-app-browser-proof.mjs",
    "deploy:netlify": "node scripts/safe-netlify-deploy.mjs",
    "eval:agent": "node scripts/eval-agent.mjs",
    "eval:agent:major": "node scripts/eval-agent.mjs --suite major-capabilities",
    "eval:agent:routing": "node scripts/eval-agent.mjs --routing-only",
    "eval:agent:cc": "node scripts/champion-challenger-agent.mjs",
    "eval:agent:cc:holdout": "node scripts/champion-challenger-agent.mjs --holdout",
    "eval:agent:cc:analyze": "node scripts/analyze-champion-challenger-report.mjs",
    "eval:agent:improve": "node scripts/run-agent-improvement-loop.mjs",
    "test:pip-money-companion-gate": "node scripts/pip-money-companion-gate.mjs",
    "dogfood:major": "node scripts/run-major-capability-dogfood.mjs",
    "dogfood:major:api": "npm run eval:agent:major && npm run eval:agent -- --suite major-capabilities-expanded && npm run eval:agent -- --suite major-capabilities-multiturn",
    "dogfood:major:production-safe": "npm run eval:agent -- --suite major-capabilities-production-safe",
    "dogfood:router": "vitest run src/lib/agent/intent-router-dogfood.test.ts",
    "dogfood:router:live": "vite-node scripts/dogfood-agent-router.mjs",
    "intent:embeddings:generate": "node scripts/generate-intent-embeddings.mjs",
    "intent:embeddings:check": "node scripts/check-intent-embeddings.mjs",
    "analyze:agent-conversations": "node scripts/analyze-agent-conversations.mjs",
    "play:reviewer:seed": "node scripts/play-review/seed-reviewer-account.mjs",
    "play:reviewer:reset": "node scripts/play-review/reset-reviewer-account.mjs",
    "play:reviewer:verify": "node scripts/play-review/verify-reviewer-account.mjs",
    "play:reporting:verify": "node scripts/play-review/verify-reporting-storage.mjs",
    "play:android-copy:verify": "node scripts/play-review/check-android-visible-copy.mjs",
    "privacy:audit-user": "node scripts/privacy/audit-user-data.mjs",
    "privacy:delete-user-data": "node scripts/privacy/delete-user-data.mjs",
    "privacy:reconcile-account-deletions": "node scripts/privacy/reconcile-account-deletions.mjs",
    "privacy:purge-agent-chats": "node scripts/privacy/purge-agent-chat-turns.mjs",
    "pip:character:import": "node scripts/pip-character/import-local-pip-assets.mjs",
    "pip:character:normalize": "node scripts/pip-character/normalize-pip-assets.mjs",
    "pip:character:review": "node scripts/pip-character/generate-pip-review-page.mjs",
    "pip:character:propose-mapping": "node scripts/pip-character/propose-pip-asset-mapping.mjs",
    "pip:character:apply-mapping": "node scripts/pip-character/apply-pip-asset-mapping.mjs",
    "pip:character:auto-select": "node scripts/pip-character/auto-select-pip-assets.mjs",
    "pip:character:check": "node scripts/pip-character/check-pip-character-assets.mjs",
    "pip:character:prepare": "npm run pip:character:import && npm run pip:character:normalize && npm run pip:character:review && npm run pip:character:propose-mapping",
    "pip:character:quick-wire": "npm run pip:character:normalize && npm run pip:character:auto-select && npm run pip:character:check"
  },
  "dependencies": {
    "@openai/agents": "^0.11.6",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "plaid": "^42.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
