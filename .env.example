# Pip chat uses the same model-backed agent path locally and in production.
# For local fake-data dogfood, set PIP_SUPABASE_MODE=off and PIP_LOCAL_FAKE_APP_MODE=1,
# then configure one model transport below. Missing model config must fail visibly;
# do not add deterministic local agent fallbacks.
OPENAI_API_KEY=
OPENAI_BASE_URL=
NETLIFY_AI_GATEWAY_BASE_URL=
NETLIFY_AI_GATEWAY_KEY=
PIP_AI_MODEL=gpt-5-nano
PIP_AI_TRANSPORT=
NEXT_PUBLIC_SITE_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Local staging needs a real service-role JWT or modern sb_secret_ key.
# Netlify hidden-secret placeholders will fail npm run check:local-staging.
SUPABASE_SERVICE_ROLE_KEY=
PIP_SUPABASE_MODE=
PIP_LOCAL_STAGING=
PIP_LOCAL_FAKE_APP_MODE=
PIP_LOCAL_AGENT_EVAL_MODE=
PIP_OPERATOR_TOKEN=
PIP_RATE_LIMIT_SALT=

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_CLIENT_NAME=Pip
PLAID_DAYS_REQUESTED=90
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=
PLAID_WEBHOOK_VERIFY=true

PIP_SYNC_JOBS_ENABLED=false
PIP_SCHEDULED_SYNC_ENABLED=false
PIP_SCHEDULED_SYNC_BATCH_SIZE=10
PIP_SCHEDULED_SYNC_MAX_JOBS=10
PIP_SCHEDULED_SYNC_MIN_INTERVAL_MINUTES=240
PIP_SAVINGS_GOALS_ENABLED=false
NEXT_PUBLIC_SAVINGS_GOALS_ENABLED=false

# Transactional email
PIP_EMAIL_MODE=off
RESEND_API_KEY=
PIP_EMAIL_FROM=Pip <hello@spendwithpip.com>
PIP_EMAIL_REPLY_TO=
PIP_EMAIL_POSTAL_ADDRESS=
PIP_EMAIL_UNSUBSCRIBE_SECRET=
RESEND_WEBHOOK_SECRET=

TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=sandbox
TELLER_PRODUCTS=transactions,balance
TELLER_CERTIFICATE_PEM=
TELLER_PRIVATE_KEY_PEM=
PIP_PROVIDER_TOKEN_KEY_BASE64=
